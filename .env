# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Database (required) ───────────────────────────────────────────────────────
DB_DSN=postgres://user:password@localhost:5432/gateway?sslmode=disable
DB_DRIVER=postgres
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=1h

# ── JWT (required — must be ≥32 chars) ───────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-plus-char-secret
JWT_ISSUER=api-gateway
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Rate limiting (token bucket, per proxied route) ───────────────────────────
RATE_TOKENS_PER_PERIOD=100
RATE_PERIOD=1m
RATE_CAPACITY=100
RATE_COST=1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Tenant-ID,X-API-Key,X-Request-ID
CORS_EXPOSED_HEADERS=X-Request-ID
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=600

# ── Security headers ──────────────────────────────────────────────────────────
SEC_HSTS=false
SEC_HSTS_MAX_AGE=31536000
SEC_FRAME_OPTIONS=DENY
SEC_CONTENT_TYPE_NOSNIFF=true
SEC_REFERRER_POLICY=strict-origin-when-cross-origin
SEC_CSP=

# ── Cache (leave CACHE_REMOTE_URL blank for local-only MemoryStore) ───────────
CACHE_REMOTE_URL=
CACHE_TIMEOUT=2s
CACHE_NAMESPACE=gateway
CACHE_TOKEN=

# ── Upstreams (JSON array; blank = no proxy routes) ───────────────────────────
# Example:
# UPSTREAMS_JSON=[{"tenant_id":"<uuid>","name":"orders","base_url":"http://localhost:9090"}]
UPSTREAMS_JSON=
